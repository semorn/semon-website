                <a href="https://larkmap.com/" target="_blank">Larkmap</a>
                <a href="https://qingicon.com/" target="_blank">QingIcon</a>
            </div>
        </div>
    </div>
    <div class="widget">
        <div class="shape-light"></div>
        <div class="shape-star">
            <div class="rising-stars rising-stars-visible">
                <div style="height:1px;width:1px"></div>
                <div style="height:2px;width:2px"></div>
                <div style="height:1px;width:1px"></div>
            </div>
        </div>
        <div class="shape-earth"></div>
    </div>
    <div class="widget-top"></div>
    <canvas class="snow-canvas" id="snow-canvas"></canvas>
</body>

<script>
    // é¦é¡µè½åæ¿åæ»å¨æç¤ºå¨

    const stickyItem = document.querySelector('#sticky-item');
    const powerList = document.querySelector('.power-list');

    // æ£æµå®¹å¨æ¯å¦å¯ä»¥æ»å¨
    function checkScroll() {
        // å¤æ­æ¯å¦æ»å¨å°æå³ä¾§
        const isAtRight = powerList.scrollLeft + powerList.clientWidth >= powerList.scrollWidth;
        if (isAtRight) {
            // æ»å¨å°æå³ä¾§æ¶éè sticky åç´ 
            stickyItem.style.opacity = 0;
        } else {
            // åå·¦æ»å¨æ¶æ¾ç¤º sticky åç´ 
            stickyItem.style.opacity = 1;
        }
    }

    // æ£æµæ¯å¦éè¦æ¾ç¤º sticky åç´ 
    function checkVisibility() {
        if (powerList.scrollWidth > powerList.clientWidth) {
            // ææ»å¨æ¡æ¶ï¼æ¾ç¤º sticky åç´ 
            stickyItem.style.opacity = 1;
        } else {
            // æ²¡ææ»å¨æ¡æ¶ï¼éè sticky åç´ 
            stickyItem.style.opacity = 0;
        }
    }

    // çå¬æ»å¨äºä»¶
    powerList.addEventListener('scroll', checkScroll);

    // çå¬çªå£å¤§å°ååäºä»¶
    window.addEventListener('resize', () => {
        checkVisibility(); // æ£æ¥æ¯å¦æ¾ç¤º sticky åç´ 
        checkScroll();     // æ£æ¥æ¯å¦æ»å¨å°æå³ä¾§
    });

    // åå§æ£æ¥
    checkVisibility();
    checkScroll();
</script>
<script src="./js/main.min.js"></script>
<script src='./js/anime.js'></script>
<script src='./js/firework.js'></script>
<script src='./js/snow.js'></script>

</html>
